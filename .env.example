# Google Antigravity SDK (for LLM Reasoning Agent)
GEMINI_API_KEY=your-gemini-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# Redis (production)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (production)
DATABASE_URL=postgresql://fraud:fraud@localhost:5432/fraud_detection

# Kafka (production)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Decision Thresholds
APPROVE_THRESHOLD=0.3
DECLINE_THRESHOLD=0.7

# Latency Budget (ms)
TOTAL_BUDGET_MS=100

# Governance
MAX_AGENT_HOPS=5
MAX_TOOL_CALLS=3
